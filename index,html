<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Manajemen Stock Barang</title>
    <link rel="manifest" href="manifest.json">
    <link rel="apple-touch-icon" href="images/icon-192x192.png">
    <meta name="theme-color" content="#4CAF50">
    <link rel="stylesheet" href="css/style.css">
</head>
<body>
    <!-- Header -->
    <header>
        <h1>📦 Manajemen Stock</h1>
        <button id="syncBtn" class="sync-btn">🔄 Sinkronisasi</button>
    </header>

    <!-- Main Content -->
    <main>
        <!-- Form Tambah Barang -->
        <section class="add-section">
            <h2>Tambah Barang</h2>
            <form id="addForm">
                <div class="form-group">
                    <label for="namaBarang">Nama Barang</label>
                    <input type="text" id="namaBarang" required placeholder="Masukkan nama barang">
                </div>
                <div class="form-group">
                    <label for="kategori">Kategori</label>
                    <input type="text" id="kategori" required placeholder="Masukkan kategori">
                </div>
                <div class="form-group">
                    <label for="jumlah">Jumlah</label>
                    <input type="number" id="jumlah" required placeholder="0" min="0">
                </div>
                <div class="form-group">
                    <label for="harga">Harga</label>
                    <input type="number" id="harga" required placeholder="0" min="0">
                </div>
                <button type="submit" class="btn-add">➕ Tambah Barang</button>
            </form>
        </section>

        <!-- Daftar Barang -->
        <section class="list-section">
            <h2>Daftar Barang</h2>
            <div class="search-box">
                <input type="text" id="searchInput" placeholder="🔍 Cari barang...">
            </div>
            <div id="stockList" class="stock-list">
                <div class="loading">Loading...</div>
            </div>
        </section>
    </main>

    <!-- Notification -->
    <div id="notification" class="notification"></div>

    <script src="js/spreadsheet.js"></script>
    <script src="js/app.js"></script>
</body>
</html>
